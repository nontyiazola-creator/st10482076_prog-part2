<Window x:Class="CybersecurityChatbott.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Chatbot"
        Height="520"
        Width="760"
        Background="Transparent"
        Foreground="White">

    <Window.Resources>

        <!-- Button style -->
        <Style TargetType="Button" x:Key="AccentButton">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF2B6FA5" Offset="0" />
                        <GradientStop Color="#FF1E5A8A" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox" x:Key="InputBox">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="#FF0F2432" />
            <Setter Property="BorderBrush" Value="#FF2B6FA5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- RichTextBox style -->
        <Style TargetType="RichTextBox" x:Key="ChatDisplay">
            <Setter Property="Background" Value="#FF071422" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>

                    <!-- FIX: Animate ONLY BgRect brush AFTER it is instantiated -->
                    <ColorAnimation Storyboard.TargetName="BgRect"
                                    Storyboard.TargetProperty="(Shape.Fill).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)"
                                    From="#FF0D1B2A" To="#FF08202E"
                                    Duration="0:0:6"
                                    AutoReverse="True"
                                    RepeatBehavior="Forever" />

                    <ColorAnimation Storyboard.TargetName="BgRect"
                                    Storyboard.TargetProperty="(Shape.Fill).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)"
                                    From="#FF123049" To="#FF18455E"
                                    Duration="0:0:8"
                                    AutoReverse="True"
                                    RepeatBehavior="Forever" />

                    <ColorAnimation Storyboard.TargetName="BgRect"
                                    Storyboard.TargetProperty="(Shape.Fill).(LinearGradientBrush.GradientStops)[2].(GradientStop.Color)"
                                    From="#FF1B3B5A" To="#FF24506F"
                                    Duration="0:0:10"
                                    AutoReverse="True"
                                    RepeatBehavior="Forever" />

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Rectangle x:Name="BgRect" Panel.ZIndex="0">
            <!-- IMPORTANT: NOT a StaticResource -->
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF0D1B2A" Offset="0" />
                    <GradientStop Color="#FF123049" Offset="0.5" />
                    <GradientStop Color="#FF1B3B5A" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Panel.ZIndex="0" Opacity="0.12">
            <Rectangle.Fill>
                <RadialGradientBrush GradientOrigin="0.2,0.1" Center="0.2,0.1" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="#FFFFFFFF" Offset="0" />
                    <GradientStop Color="#00FFFFFF" Offset="0.6" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10" Orientation="Horizontal">

            <Viewbox Width="48" Height="48" Margin="0,0,10,0">
                <Canvas Width="24" Height="24">
                    <Path Fill="#FF2B6FA5" Stroke="White" StrokeThickness="0.5"
                          Data="M12,2 L4,5 v6 c0,5 4.7,9.2 8,11 3.3-1.8 8-6 8-11 V5 L12,2 z M12,7 a5,5 0 1,1 0,10 a5,5 0 1,1 0,-10 z"/>
                </Canvas>
            </Viewbox>

            <StackPanel>
                <TextBlock Text="Cybersecurity Awareness Assistant"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="Bot: CyberBot — built to keep you safe online"
                           FontSize="12"
                           Foreground="#FFBFDFF6"/>
            </StackPanel>

        </StackPanel>

        <!-- CHAT BOX -->
        <RichTextBox Grid.Row="1"
                     Name="rtbChatDisplay"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     Style="{StaticResource ChatDisplay}" />

        <!-- INPUT AREA -->
        <Grid Grid.Row="2" Margin="0,5,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="txtUserInput"
                     Grid.Column="0"
                     Style="{StaticResource InputBox}"
                     KeyDown="txtUserInput_KeyDown"/>

            <Button Grid.Column="1" Content="Send" Click="btnSend_Click" Style="{StaticResource AccentButton}"/>
            <Button Grid.Column="2" Content="Clear" Click="btnClear_Click" Style="{StaticResource AccentButton}"/>
            <Button Grid.Column="3" Content="Save" Click="btnSave_Click" Style="{StaticResource AccentButton}"/>
            <Button Grid.Column="4" Content="Load" Click="btnLoad_Click" Style="{StaticResource AccentButton}"/>
            <Button Grid.Column="5" Content="Export" Click="btnExport_Click" Style="{StaticResource AccentButton}"/>

        </Grid>

    </Grid>

</Window>